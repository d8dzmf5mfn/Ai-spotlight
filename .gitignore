.DS_Store
.build/
.swiftpm/
*.xcodeproj/
Package.resolved
Secrets.plist

# .app bundle output (regenerated by scripts/make_app.sh)
build/

# Belt-and-suspenders: prevent any .dmg from being committed, anywhere.
# scripts/make_dmg.sh only writes to build/ (already ignored above), so
# the only way a .dmg could sneak in is if someone copies one to the
# repo root by hand. Keep this rule to make that mistake a no-op.
*.dmg

# LLM tooling folder — per-machine skills, debug notes, session logs.
# Managed by the AI coding assistant. See README "Project notes".
.hermes/

# GitHub CLI local state (auth, device id). Never commit.
.local/

# Unrelated research notes dropped at the project root.
# (Spaces in dirname require no quotes here — git pattern matches literally.)
ChatGPT solution (provided by Chatgpt contain solution only)/

# Local test log (lives in ~/Documents, but ignore anywhere it shows up)
AI-Spotlight-Testing.md
